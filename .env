# MySQL Host Configuration (MySQL runs on HOST, not in Docker)
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=finance_db

# MySQL ROOT credentials (used only during first-run setup to create DB/user)
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=root

# JWT Auth
JWT_SECRET_KEY=f3a8b2c9d1e4f7a0b5c8d2e6f9a3b7c1d4e8f2a5b9c3d7e1f4a8b2c6d9e3f7
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Admin Credentials (single admin user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_secure_password_2024

# App
APP_HOST=0.0.0.0
APP_PORT=8000
